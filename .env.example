# =============================================================================
# Flask Blog 环境变量配置
# 将此文件复制为 .env 并填入实际值：
#     cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# 内容目录
# ---------------------------------------------------------------------------
# 文章和主题的 Markdown 文件所在目录，默认为项目根目录下的 content/
# BLOG_CONTENT_DIR=content

# ---------------------------------------------------------------------------
# 分页设置
# ---------------------------------------------------------------------------
# 首页每页显示的文章数量，默认 20
# BLOG_POSTS_PER_PAGE=20

# ---------------------------------------------------------------------------
# 主题
# ---------------------------------------------------------------------------
# 使用的主题名称，对应 blog/templates/<theme>/ 目录，默认 light
# BLOG_THEME=light

# ---------------------------------------------------------------------------
# 安全
# ---------------------------------------------------------------------------
# Flask 会话加密密钥，生产环境必须使用强随机字符串
# 默认值仅用于开发，切勿在生产环境使用
# BLOG_SECRET_KEY=dev-secret-key
