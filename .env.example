# =============================================================================
# Flask Blog 环境变量配置
# 将此文件复制为 .env 并填入实际值：
#     cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# 内容目录
# ---------------------------------------------------------------------------
# 文章和主题的 Markdown 文件所在目录，默认为项目根目录下的 content/
# BLOG_CONTENT_DIR=content

# ---------------------------------------------------------------------------
# 分页设置
# ---------------------------------------------------------------------------
# 首页每页显示的文章数量，默认 20
# BLOG_POSTS_PER_PAGE=20

# ---------------------------------------------------------------------------
# 主题
# ---------------------------------------------------------------------------
# 使用的主题名称，对应 blog/templates/<theme>/ 目录，默认 light
# BLOG_THEME=light

# ---------------------------------------------------------------------------
# 安全
# ---------------------------------------------------------------------------
# Flask 会话加密密钥，生产环境必须使用强随机字符串
# 默认值仅用于开发，切勿在生产环境使用
# BLOG_SECRET_KEY=dev-secret-key

# ---------------------------------------------------------------------------
# Webhook（GitHub 远程触发 git pull）
# ---------------------------------------------------------------------------
# GitHub Webhook 密钥，用于校验 X-Hub-Signature-256 签名；留空则禁用接口
# （POST /webhook/github 返回 404）。需与 GitHub 仓库 Webhook 设置中的 Secret 一致
# BLOG_WEBHOOK_SECRET=

# 仅监听该 ref 的 push 事件（如 refs/heads/main）；留空表示所有分支的 push 都触发
# BLOG_WEBHOOK_REF=refs/heads/main

# 执行 git pull 的仓库目录，默认为项目根目录
# BLOG_WEBHOOK_REPO_DIR=

# webhook 日志目录，默认为项目根目录下的 logs/，按天滚动（webhook.log）
# BLOG_LOG_DIR=logs

# ---------------------------------------------------------------------------
# 文章发布页面 /postart
# ---------------------------------------------------------------------------
# /postart 访问密码；留空则禁用发布入口（访问返回 404）
# BLOG_POSTART_PASSWORD=

# 新文章默认作者，留空则不写 authors 字段
# BLOG_POSTART_AUTHOR=

# LLM（OpenAI 兼容接口），用于发布时自动生成 slug 和简介
# base_url 示例：OpenAI https://api.openai.com/v1
#               DeepSeek https://api.deepseek.com/v1
#               火山引擎 https://ark.cn-beijing.volces.com/api/v3
# model 示例：gpt-4o-mini / deepseek-chat / doubao-pro-32k
# BLOG_LLM_BASE_URL=
# BLOG_LLM_API_KEY=
# BLOG_LLM_MODEL=

# ---------------------------------------------------------------------------
# 网页导入图片转存
# ---------------------------------------------------------------------------
# 发布入口「抓取网页」时，会把正文中的远程图片下载并转存到对象存储，
# 避免外链失效。OSS 与 R2 互斥，由下面的 BLOG_IMAGE_STORAGE 选择启用哪个。
# 选 oss 时需配齐 BLOG_OSS_* 四项；选 r2 时需配齐 BLOG_R2_* 五项。
# BLOG_IMAGE_STORAGE=oss

# 阿里云 OSS（四项齐全时启用）
# endpoint 示例：oss-cn-hangzhou.aliyuncs.com（不带 bucket、不带协议）
# BLOG_OSS_ACCESS_KEY_ID=
# BLOG_OSS_ACCESS_KEY_SECRET=
# BLOG_OSS_ENDPOINT=
# BLOG_OSS_BUCKET=

# Cloudflare R2（五项齐全时启用；与 OSS 互斥）
# account_id 用于拼接 <account_id>.r2.cloudflarestorage.com 端点
# public_base_url 为已配置的公开访问基址（自定义域名或 *.r2.dev）
# BLOG_R2_ACCOUNT_ID=
# BLOG_R2_ACCESS_KEY_ID=
# BLOG_R2_SECRET_ACCESS_KEY=
# BLOG_R2_BUCKET=
# BLOG_R2_PUBLIC_BASE_URL=
